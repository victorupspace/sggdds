{
  "name": "@government/design-system",
  "version": "0.1.0",
  "description": "Fundacao tecnica de Design System governamental para React, Storybook e design tokens multiplataforma.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "license": "UNLICENSED",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/foundations/tokens/css/tokens.css",
    "./tokens.json": "./src/foundations/tokens/build/tokens.json"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "storybook": "storybook dev -p 6006 --host 0.0.0.0",
    "build-storybook": "storybook build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "tokens:build": "tsx scripts/tokens/transform-tokens.ts",
    "tokens:validate": "tsx scripts/tokens/validate-tokens.ts",
    "tokens:clean": "rimraf src/foundations/tokens/build src/foundations/tokens/css",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@storybook/addon-a11y": "10.3.6",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/addon-vitest": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "playwright": "1.59.1",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "storybook": "10.3.6",
    "style-dictionary": "5.4.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.24.0"
  }
}
